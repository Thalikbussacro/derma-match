# Variáveis de ambiente do backend.
# Copie para .env e preencha. As variáveis são adicionadas conforme as tasks avançam.

# Aplicação
NODE_ENV=development
PORT=3000
# Nº de proxies confiáveis à frente (0 = direto). Atrás de nginx/LB, use o nº de hops (ex.: 1).
TRUST_PROXY=0
# Origens permitidas pelo CORS, separadas por vírgula.
CORS_ORIGIN=http://localhost:5173

# Conexão com o Postgres (host/porta do docker-compose)
DATABASE_URL="postgresql://derma:derma@localhost:5433/derma_match?schema=public"

# Credenciais e porta de host usadas pelo docker-compose para o Postgres local.
# A porta de host é 5433 por padrão para não colidir com um Postgres já rodando na 5432.
POSTGRES_USER=derma
POSTGRES_PASSWORD=derma
POSTGRES_DB=derma_match
POSTGRES_HOST_PORT=5433

# JWT — use segredos com pelo menos 32 caracteres (ex.: openssl rand -base64 48)
JWT_ACCESS_SECRET="troque_por_um_segredo_forte_de_32_ou_mais_chars"
JWT_REFRESH_SECRET="troque_por_outro_segredo_forte_de_32_ou_mais_chars"
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# SMTP — em dev use Mailtrap (https://mailtrap.io); preencha USER/PASS com as credenciais da inbox
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Derma Match <nao-responda@dermamatch.local>"
# URL base do frontend, usada para montar o link de redefinição de senha
APP_URL=http://localhost:5173
