// Schema do Prisma. Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TipoPele {
  id        Int    @id @default(autoincrement())
  nome      String @unique @db.VarChar(40)
  descricao String

  @@map("tipos_pele")
}
