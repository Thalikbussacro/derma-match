// Schema do Prisma. Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plano {
  FREE
  PREMIUM
}

model TipoPele {
  id        Int    @id @default(autoincrement())
  nome      String @unique @db.VarChar(40)
  descricao String

  usuariosPredominantes Usuario[]

  @@map("tipos_pele")
}

model Usuario {
  id                     Int      @id @default(autoincrement())
  nome                   String   @db.VarChar(120)
  email                  String   @unique @db.VarChar(160)
  senhaHash              String   @map("senha_hash") @db.VarChar(255)
  plano                  Plano    @default(FREE)
  tipoPelePredominanteId Int?     @map("tipo_pele_predominante_id")
  consentimentoLgpdEm    DateTime @map("consentimento_lgpd_em")
  criadoEm               DateTime  @default(now()) @map("criado_em")
  atualizadoEm           DateTime  @updatedAt @map("atualizado_em")
  tentativasLoginFalhas  Int       @default(0) @map("tentativas_login_falhas")
  bloqueadoAte           DateTime? @map("bloqueado_ate")

  tipoPelePredominante   TipoPele?               @relation(fields: [tipoPelePredominanteId], references: [id])
  refreshTokens          RefreshToken[]
  tokensRecuperacaoSenha TokenRecuperacaoSenha[]

  @@map("usuarios")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  usuarioId  Int       @map("usuario_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiraEm   DateTime  @map("expira_em")
  revogadoEm DateTime? @map("revogado_em")
  criadoEm   DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, revogadoEm])
  @@map("refresh_tokens")
}

model TokenRecuperacaoSenha {
  id        Int       @id @default(autoincrement())
  usuarioId Int       @map("usuario_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiraEm  DateTime  @map("expira_em")
  usadoEm   DateTime? @map("usado_em")
  criadoEm  DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, usadoEm])
  @@map("tokens_recuperacao_senha")
}
