// Schema do Prisma. Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plano {
  FREE
  PREMIUM
}

model TipoPele {
  id        Int    @id @default(autoincrement())
  nome      String @unique @db.VarChar(40)
  descricao String
  ordem     Int    @default(0) // posição no espectro (C3); usada para calcular o nível 1–5

  usuariosPredominantes Usuario[]
  pesos                 PesoOpcaoPele[]
  rotina                Rotina?

  @@map("tipos_pele")
}

model Usuario {
  id                            Int       @id @default(autoincrement())
  nome                          String    @db.VarChar(120)
  email                         String    @unique @db.VarChar(160)
  senhaHash                     String    @map("senha_hash") @db.VarChar(255)
  plano                         Plano     @default(FREE)
  tipoPelePredominanteId        Int?      @map("tipo_pele_predominante_id")
  tipoPeleNivel                 Int?      @map("tipo_pele_nivel")
  metaPele                      String?   @map("meta_pele")
  questionarioVersaoId          Int?      @map("questionario_versao_id")
  consentimentoLgpdEm           DateTime  @map("consentimento_lgpd_em")
  consentimentoVersao           String    @default("1.0") @map("consentimento_versao") @db.VarChar(20)
  consentimentoDadosSensiveisEm DateTime? @map("consentimento_dados_sensiveis_em")
  criadoEm                      DateTime  @default(now()) @map("criado_em")
  atualizadoEm                  DateTime  @updatedAt @map("atualizado_em")
  tentativasLoginFalhas         Int       @default(0) @map("tentativas_login_falhas")
  bloqueadoAte                  DateTime? @map("bloqueado_ate")

  tipoPelePredominante   TipoPele?               @relation(fields: [tipoPelePredominanteId], references: [id])
  questionarioVersao     QuestionarioVersao?     @relation(fields: [questionarioVersaoId], references: [id])
  refreshTokens          RefreshToken[]
  tokensRecuperacaoSenha TokenRecuperacaoSenha[]
  respostas              RespostaUsuario[]
  conversas              Conversa[]
  rotinaPersonalizada    RotinaPersonalizada?
  registrosDiario        RegistroDiario[]
  checkinsRotina         CheckinRotina[]

  @@map("usuarios")
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  usuarioId   Int?      @map("usuario_id")
  biomedicaId Int?      @map("biomedica_id")
  adminId     Int?      @map("admin_id")
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255)
  expiraEm    DateTime  @map("expira_em")
  revogadoEm  DateTime? @map("revogado_em")
  criadoEm    DateTime  @default(now()) @map("criado_em")

  usuario   Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  biomedica Biomedica? @relation(fields: [biomedicaId], references: [id], onDelete: Cascade)
  admin     Admin?     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  // Exatamente um dono (usuária XOR biomédica XOR admin) garantido por check constraint na migração.
  @@index([usuarioId, revogadoEm])
  @@index([biomedicaId, revogadoEm])
  @@index([adminId, revogadoEm])
  @@map("refresh_tokens")
}

model TokenRecuperacaoSenha {
  id        Int       @id @default(autoincrement())
  usuarioId Int       @map("usuario_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiraEm  DateTime  @map("expira_em")
  usadoEm   DateTime? @map("usado_em")
  criadoEm  DateTime  @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, usadoEm])
  @@map("tokens_recuperacao_senha")
}

enum StatusQuestionario {
  RASCUNHO
  PUBLICADO
  ARQUIVADO
}

// Versão do questionário. No máximo uma PUBLICADO por vez; edições ocorrem sobre um RASCUNHO.
model QuestionarioVersao {
  id          Int                @id @default(autoincrement())
  numero      Int                @unique
  status      StatusQuestionario @default(RASCUNHO)
  publicadoEm DateTime?          @map("publicado_em")
  criadoEm    DateTime           @default(now()) @map("criado_em")

  perguntas Pergunta[]
  usuarios  Usuario[]

  @@map("questionario_versoes")
}

model Pergunta {
  id                   Int    @id @default(autoincrement())
  questionarioVersaoId Int    @map("questionario_versao_id")
  texto                String
  ordem                Int
  dependeDeOpcaoId     Int?   @map("depende_de_opcao_id")

  versao         QuestionarioVersao @relation(fields: [questionarioVersaoId], references: [id], onDelete: Cascade)
  opcoes         OpcaoResposta[]    @relation("PerguntaOpcoes")
  dependeDeOpcao OpcaoResposta?     @relation("OpcaoDependencia", fields: [dependeDeOpcaoId], references: [id])
  respostas      RespostaUsuario[]

  // Ordem única por versão (a navegação apresenta por `ordem` dentro da versão).
  @@unique([questionarioVersaoId, ordem])
  @@map("perguntas")
}

model OpcaoResposta {
  id         Int    @id @default(autoincrement())
  perguntaId Int    @map("pergunta_id")
  texto      String @db.VarChar(200)

  pergunta             Pergunta               @relation("PerguntaOpcoes", fields: [perguntaId], references: [id], onDelete: Cascade)
  pesos                PesoOpcaoPele[]
  respostas            RespostaUsuario[]
  perguntasDependentes Pergunta[]             @relation("OpcaoDependencia")
  produtosSugeridos    OpcaoProdutoSugerido[]

  @@map("opcoes_resposta")
}

model Produto {
  id        Int         @id @default(autoincrement())
  nome      String      @db.VarChar(120)
  marca     String?     @db.VarChar(80)
  etapa     EtapaRotina
  descricao String
  ativo     Boolean     @default(true)
  criadoEm  DateTime    @default(now()) @map("criado_em")

  sugestoes   OpcaoProdutoSugerido[]
  itensRotina ItemRotinaPersonalizada[]

  @@map("produtos")
}

// Rotina personalizada por paciente (override da rotina base do tipo — ADR-0016 / C6).
model RotinaPersonalizada {
  id           Int      @id @default(autoincrement())
  usuarioId    Int      @unique @map("usuario_id")
  biomedicaId  Int      @map("biomedica_id")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuario    Usuario                   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  biomedica  Biomedica                 @relation(fields: [biomedicaId], references: [id])
  itens      ItemRotinaPersonalizada[]
  alteracoes RotinaAlteracao[]

  @@map("rotinas_personalizadas")
}

model ItemRotinaPersonalizada {
  id                    Int         @id @default(autoincrement())
  rotinaPersonalizadaId Int         @map("rotina_personalizada_id")
  etapa                 EtapaRotina
  descricao             String
  ordem                 Int
  produtoId             Int?        @map("produto_id")

  rotina  RotinaPersonalizada @relation(fields: [rotinaPersonalizadaId], references: [id], onDelete: Cascade)
  produto Produto?            @relation(fields: [produtoId], references: [id])

  @@index([rotinaPersonalizadaId, ordem])
  @@map("itens_rotina_personalizada")
}

// --- Acompanhamento contínuo (Fase 7 — ADR-0017) ---

// Diário de pele: a usuária registra como a pele está ao longo do tempo (sem foto).
model RegistroDiario {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  condicao  Int // 1 (ruim) a 5 (ótima)
  tags      String[]
  nota      String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, criadoEm])
  @@map("registros_diario")
}

// Adesão: um check-in por dia (a usuária confirma que seguiu a rotina).
model CheckinRotina {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  dia       DateTime @db.Date
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, dia])
  @@map("checkins_rotina")
}

// Conteúdo educativo publicado pelo admin.
model Dica {
  id       Int      @id @default(autoincrement())
  titulo   String   @db.VarChar(160)
  conteudo String
  ativa    Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("dicas")
}

// Trilha clínica: quem alterou a rotina da paciente e quando.
model RotinaAlteracao {
  id                    Int      @id @default(autoincrement())
  rotinaPersonalizadaId Int      @map("rotina_personalizada_id")
  biomedicaId           Int      @map("biomedica_id")
  resumo                String
  alteradoEm            DateTime @default(now()) @map("alterado_em")

  rotina    RotinaPersonalizada @relation(fields: [rotinaPersonalizadaId], references: [id], onDelete: Cascade)
  biomedica Biomedica           @relation(fields: [biomedicaId], references: [id])

  @@index([rotinaPersonalizadaId, alteradoEm])
  @@map("rotina_alteracoes")
}

// Produtos sugeridos por uma opção de resposta (ponto de partida da rotina — C4/C6).
model OpcaoProdutoSugerido {
  opcaoId   Int @map("opcao_id")
  produtoId Int @map("produto_id")

  opcao   OpcaoResposta @relation(fields: [opcaoId], references: [id], onDelete: Cascade)
  produto Produto       @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@id([opcaoId, produtoId])
  @@map("opcao_produto_sugerido")
}

model PesoOpcaoPele {
  opcaoId    Int @map("opcao_id")
  tipoPeleId Int @map("tipo_pele_id")
  peso       Int

  opcao    OpcaoResposta @relation(fields: [opcaoId], references: [id], onDelete: Cascade)
  tipoPele TipoPele      @relation(fields: [tipoPeleId], references: [id])

  @@id([opcaoId, tipoPeleId])
  @@map("pesos_opcao_pele")
}

model RespostaUsuario {
  id           Int      @id @default(autoincrement())
  usuarioId    Int      @map("usuario_id")
  perguntaId   Int      @map("pergunta_id")
  opcaoId      Int      @map("opcao_id")
  respondidoEm DateTime @default(now()) @map("respondido_em")

  usuario  Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pergunta Pergunta      @relation(fields: [perguntaId], references: [id], onDelete: Cascade)
  opcao    OpcaoResposta @relation(fields: [opcaoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, perguntaId])
  @@index([usuarioId])
  @@map("respostas_usuario")
}

enum EtapaRotina {
  LIMPEZA
  TONIFICACAO
  HIDRATACAO
  PROTECAO_SOLAR
  TRATAMENTO
}

model Rotina {
  id         Int    @id @default(autoincrement())
  tipoPeleId Int    @unique @map("tipo_pele_id")
  descricao  String

  tipoPele TipoPele     @relation(fields: [tipoPeleId], references: [id])
  itens    ItemRotina[]

  @@map("rotinas")
}

model ItemRotina {
  id        Int         @id @default(autoincrement())
  rotinaId  Int         @map("rotina_id")
  etapa     EtapaRotina
  descricao String
  ordem     Int

  rotina Rotina @relation(fields: [rotinaId], references: [id], onDelete: Cascade)

  @@index([rotinaId, ordem])
  @@map("itens_rotina")
}

// --- Premium (Fase 5) ---

model Biomedica {
  id           Int      @id @default(autoincrement())
  nome         String   @db.VarChar(120)
  registro     String   @unique @db.VarChar(40) // registro profissional (ex.: CRBM)
  email        String   @unique @db.VarChar(160)
  senhaHash    String   @map("senha_hash") @db.VarChar(255)
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  refreshTokens         RefreshToken[]
  conversas             Conversa[]
  rotinasPersonalizadas RotinaPersonalizada[]
  alteracoesRotina      RotinaAlteracao[]

  @@map("biomedicas")
}

model Admin {
  id           Int      @id @default(autoincrement())
  nome         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(160)
  senhaHash    String   @map("senha_hash") @db.VarChar(255)
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  refreshTokens RefreshToken[]

  @@map("admins")
}

model Conversa {
  id              Int      @id @default(autoincrement())
  usuarioId       Int      @map("usuario_id")
  biomedicaId     Int      @map("biomedica_id")
  criadoEm        DateTime @default(now()) @map("criado_em")
  ultimaAtividade DateTime @default(now()) @map("ultima_atividade")

  usuario   Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  biomedica Biomedica  @relation(fields: [biomedicaId], references: [id])
  mensagens Mensagem[]

  // Uma conversa ativa por usuária, atribuída a uma única biomédica (ADR-0016 / C5).
  @@unique([usuarioId])
  @@index([biomedicaId, ultimaAtividade])
  @@map("conversas")
}

enum AutorMensagem {
  USUARIA
  BIOMEDICA
}

model Mensagem {
  id         Int           @id @default(autoincrement())
  conversaId Int           @map("conversa_id")
  autorTipo  AutorMensagem @map("autor_tipo")
  autorId    Int           @map("autor_id")
  conteudo   String
  criadoEm   DateTime      @default(now()) @map("criado_em")

  conversa Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  anexos   Anexo[]

  @@index([conversaId, criadoEm])
  @@map("mensagens")
}

model Anexo {
  id            Int      @id @default(autoincrement())
  mensagemId    Int      @map("mensagem_id")
  tipo          String   @db.VarChar(100) // mime type
  caminho       String // caminho no storage local
  dataExpiracao DateTime @map("data_expiracao")
  criadoEm      DateTime @default(now()) @map("criado_em")

  mensagem Mensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)

  @@index([dataExpiracao])
  @@map("anexos")
}
